{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "validate": "ts-node scripts/validar-reprocesamiento.ts",
    "recover": "ts-node scripts/recuperar-pedidos-huerfanos.ts",
    "recover:real": "ts-node scripts/recuperar-pedidos-huerfanos.ts --real",
    "simulate": "ts-node scripts/simular-casos-prueba.ts --caso=todos",
    "simulate:timing": "ts-node scripts/simular-casos-prueba.ts --caso=timing",
    "simulate:normal": "ts-node scripts/simular-casos-prueba.ts --caso=normal",
    "simulate:pack": "ts-node scripts/simular-casos-prueba.ts --caso=pack-incompleto",
    "pre-deploy": "npm run lint && npm run build && npm run test && npm run simulate",
    "post-deploy": "npm run validate"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@google-cloud/secret-manager": "^5.5.0",
    "@types/nodemailer": "^7.0.3",
    "axios": "^1.7.2",
    "firebase-admin": "^12.1.0",
    "firebase-functions": "^6.4.0",
    "luxon": "^3.7.1",
    "nodemailer": "^7.0.10",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/luxon": "^3.6.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "eslint": "^9.30.1",
    "eslint-config-google": "^0.14.0",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "firebase-functions-test": "^3.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "private": true
}
